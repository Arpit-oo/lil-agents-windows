{
  "name": "lil-agents-windows",
  "version": "1.0.0",
  "description": "Animated AI companions that walk on your Windows taskbar",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "tsc && electron .",
    "dev:no-tray": "set LIL_AGENTS_NO_TRAY=1&& tsc && electron . --no-sandbox --disable-http-cache --disable-gpu-shader-disk-cache --disable-gpu-disk-cache",
    "build": "tsc",
    "start": "electron .",
    "pack": "electron-builder --win portable",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "electron": "^41.2.0",
    "electron-store": "^11.0.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
